{
	"name": "vscode-git-timewarp",
	"displayName": "Git Timewarp",
	"description": "Navigate through a file's history in-place with keyboard shortcuts — treating time as a navigable dimension in the editor.",
	"version": "1.1.0",
	"publisher": "arcmantle",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/arcmantle/vscode-git-timewarp"
	},
	"icon": "media/icon.png",
	"type": "module",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:gitTimewarp.back",
		"onCommand:gitTimewarp.forward",
		"onCommand:gitTimewarp.returnToPresent",
		"onCommand:gitTimewarp.enterTimewarpView",
		"onCommand:gitTimewarp.showLocalHistoryDiagnostics"
	],
	"main": "./dist/extension.mjs",
	"contributes": {
		"commands": [
			{
				"command": "gitTimewarp.back",
				"title": "Git Timewarp: Step Back in History"
			},
			{
				"command": "gitTimewarp.forward",
				"title": "Git Timewarp: Step Forward in History"
			},
			{
				"command": "gitTimewarp.returnToPresent",
				"title": "Git Timewarp: Return to Present"
			},
			{
				"command": "gitTimewarp.enterTimewarpView",
				"title": "Git Timewarp: Enter Scroll Mode"
			},
			{
				"command": "gitTimewarp.showLocalHistoryDiagnostics",
				"title": "Git Timewarp: Show Local History Diagnostics"
			},
			{
				"command": "gitTimewarp.webview.back",
				"title": "Git Timewarp: Step Back (Webview)"
			},
			{
				"command": "gitTimewarp.webview.forward",
				"title": "Git Timewarp: Step Forward (Webview)"
			},
			{
				"command": "gitTimewarp.webview.splitPresent",
				"title": "Git Timewarp: Toggle Split View (Present)"
			},
			{
				"command": "gitTimewarp.webview.splitPrevious",
				"title": "Git Timewarp: Toggle Split View (Previous Commit)"
			}
		],
		"keybindings": [
			{
				"command": "gitTimewarp.back",
				"key": "alt+,",
				"mac": "alt+,",
				"when": "editorTextFocus"
			},
			{
				"command": "gitTimewarp.forward",
				"key": "alt+.",
				"mac": "alt+.",
				"when": "editorTextFocus"
			},
			{
				"command": "gitTimewarp.returnToPresent",
				"key": "escape",
				"when": "editorTextFocus && gitTimewarp.isTimeWarping"
			},
			{
				"command": "gitTimewarp.enterTimewarpView",
				"key": "alt+t",
				"mac": "alt+t",
				"when": "editorTextFocus"
			},
			{
				"command": "gitTimewarp.webview.back",
				"key": "alt+,",
				"mac": "alt+,",
				"when": "activeWebviewPanelId == 'gitTimewarp.scrollView'"
			},
			{
				"command": "gitTimewarp.webview.forward",
				"key": "alt+.",
				"mac": "alt+.",
				"when": "activeWebviewPanelId == 'gitTimewarp.scrollView'"
			},
			{
				"command": "gitTimewarp.webview.splitPresent",
				"key": "alt+s",
				"mac": "alt+s",
				"when": "activeWebviewPanelId == 'gitTimewarp.scrollView'"
			},
			{
				"command": "gitTimewarp.webview.splitPrevious",
				"key": "alt+d",
				"mac": "alt+d",
				"when": "activeWebviewPanelId == 'gitTimewarp.scrollView'"
			}
		],
		"configuration": {
			"title": "Git Timewarp",
			"properties": {
				"gitTimewarp.cacheSize": {
					"type": "number",
					"default": 50,
					"minimum": 5,
					"description": "Number of file versions to keep in memory cache."
				},
				"gitTimewarp.includeLocalHistory": {
					"type": "boolean",
					"default": true,
					"description": "Include VS Code local history entries in the timeline."
				},
				"gitTimewarp.maxCommits": {
					"type": "number",
					"default": 200,
					"minimum": 10,
					"description": "Maximum number of commits to load per file."
				},
				"gitTimewarp.debounceMs": {
					"type": "number",
					"default": 150,
					"minimum": 0,
					"maximum": 1000,
					"description": "Debounce delay (ms) when navigating rapidly. Set to 0 for instant switching."
				},
				"gitTimewarp.splitPresentLayout": {
					"type": "string",
					"enum": [
						"current-left",
						"current-right"
					],
					"enumDescriptions": [
						"Show the historical commit on the left and the present file on the right.",
						"Show the present file on the left and the historical commit on the right."
					],
					"default": "current-left",
					"description": "Panel order when comparing a historical commit against the present file."
				},
				"gitTimewarp.splitPreviousLayout": {
					"type": "string",
					"enum": [
						"current-left",
						"current-right"
					],
					"enumDescriptions": [
						"Show the current commit on the left and the previous commit on the right.",
						"Show the previous commit on the left and the current commit on the right."
					],
					"default": "current-left",
					"description": "Panel order when comparing the current commit against its previous commit."
				}
			}
		}
	},
	"scripts": {
		"build": "node esbuild.config.mjs",
		"watch": "node esbuild.config.mjs --watch",
		"lint": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.9.1",
		"esbuild": "^0.24.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"lit": "^3.3.3",
		"shiki": "^4.1.0"
	}
}